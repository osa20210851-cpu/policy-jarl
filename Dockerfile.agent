FROM python:3.11-slim

# Create a non-privileged user
RUN groupadd -g 1001 jarl_group && \
    useradd -u 1001 -g jarl_group -s /bin/bash -m jarl_user

WORKDIR /app

# Install base dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt nanobot-ai[api] httpx

# SECURITY: Remove package management to prevent runtime improvisations
RUN rm -f /usr/local/bin/pip* && \
    rm -rf /root/.cache

# Setup the Nanobot home directory
RUN mkdir -p /home/jarl_user/.nanobot && \
    chown -R jarl_user:jarl_group /home/jarl_user/.nanobot

# Switch to non-root context
USER jarl_user
ENV HOME=/home/jarl_user

# Start the agent as a pure worker
CMD ["nanobot", "serve", \
     "--host", "0.0.0.0", \
     "--port", "8900", \
     "--timeout", "300", \
     "--config", "/home/jarl_user/.nanobot/config.json", \
     "--workspace", "/home/jarl_user/.nanobot/workspace"]
